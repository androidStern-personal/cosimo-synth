     ============================================================ -->
<section class="section section--cream" style="--accent: #C18B4F;">
  <header class="section__head">
    <span class="section__sub">11</span>
    <span class="section__title">Synth Controls</span>
  </header>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Step grid</span><span class="row__lead-name">16 steps · on / off / accent / head</span></div>
    <div class="cell" style="flex: 1; align-items: stretch;">
      <div class="step-grid">
