    <div class="cell">
      <svg class="knob knob--lg" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="58 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.78</span>
    </div>
    <div class="cell">
      <svg class="knob knob--xl" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="68 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.90</span>
    </div>
  </div>
</section>

<!-- BIPOLAR KNOBS -->
<section class="section section--cream-warm" style="--accent: #2E8B7B;">
  <header class="section__head">
    <span class="section__sub">03</span>
    <span class="section__title">Knobs · Bipolar</span>
  </header>

  <div class="row">
    <div class="row__lead">
      <span class="row__lead-cap">Range</span>
      <span class="row__lead-name">−1.0 → 0 → +1.0</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 0 37.5 62.5" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">−1.00</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 11.25 26.25 62.5" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">−0.70</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 22.5 15 62.5" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">−0.40</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">0.00</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 15 47.5" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">+0.40</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 26.25 36.25" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">+0.70</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 37.5 25" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">+1.00</span>
    </div>
  </div>
</section>

<section class="section section--dark" style="--accent: #6CF3A9;">
  <header class="section__head">
    <span class="section__sub">04</span>
