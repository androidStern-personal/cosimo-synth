<section class="section section--cream" style="--accent: #C18B4F;">
  <header class="section__head">
    <span class="section__sub">09</span>
    <span class="section__title">Buttons</span>
  </header>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Pill</span><span class="row__lead-name">on / off</span></div>
    <div class="cell"><span class="pill pill--on">Active</span></div>
    <div class="cell"><span class="pill">Inactive</span></div>
    <div class="cell"><span class="pill">S</span></div>
    <div class="cell"><span class="pill pill--on">M</span></div>
    <div class="cell"><span class="pill">Post</span></div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Square</span><span class="row__lead-name">on / off</span></div>
    <div class="cell"><span class="square square--on">Bypass</span></div>
    <div class="cell"><span class="square">Bypass</span></div>
    <div class="cell"><span class="square square--on">Hold</span></div>
    <div class="cell"><span class="square">Latch</span></div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Segmented</span><span class="row__lead-name">one of N</span></div>
    <div class="cell">
      <div class="segmented">
        <span class="segmented__item segmented__item--on">LP</span>
        <span class="segmented__item">BP</span>
        <span class="segmented__item">HP</span>
        <span class="segmented__item">Notch</span>
      </div>
    </div>
    <div class="cell">
      <div class="segmented">
        <span class="segmented__item">×1</span>
        <span class="segmented__item segmented__item--on">×2</span>
        <span class="segmented__item">×4</span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Tabs</span><span class="row__lead-name">underline marks active</span></div>
    <div class="cell" style="align-items: flex-start;">
      <div class="tabs">
        <span class="tabs__item tabs__item--on">Wavetable</span>
        <span class="tabs__item">Sample</span>
        <span class="tabs__item">Granular</span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Toggle</span><span class="row__lead-name">two-state</span></div>
    <div class="cell"><div class="toggle"><span class="toggle__handle"></span></div><span class="cell__cap">off</span></div>
    <div class="cell"><div class="toggle toggle--on" style="--on: 1;"><span class="toggle__handle"></span></div><span class="cell__cap">on</span></div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Radio</span><span class="row__lead-name">one of N</span></div>
    <div class="cell" style="flex-direction: row; gap: 24px; align-items: center;">
      <span class="radio radio--on"><span class="radio__circle"></span>Mono</span>
      <span class="radio"><span class="radio__circle"></span>Poly</span>
      <span class="radio"><span class="radio__circle"></span>Legato</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Check</span><span class="row__lead-name">independent flags</span></div>
    <div class="cell" style="flex-direction: row; gap: 24px; align-items: center;">
      <span class="check check--on"><span class="check__box"></span>Sync</span>
      <span class="check"><span class="check__box"></span>Retrig</span>
      <span class="check check--on"><span class="check__box"></span>Loop</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Dropdown</span><span class="row__lead-name">menu trigger</span></div>
    <div class="cell"><div class="dropdown">Concert · Wide<span class="dropdown__caret">▾</span></div></div>
    <div class="cell"><div class="dropdown">Linear<span class="dropdown__caret">▾</span></div></div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Stepper</span><span class="row__lead-name">discrete value</span></div>
    <div class="cell"><div class="stepper"><span class="stepper__btn">−</span><span class="stepper__val">+2</span><span class="stepper__btn">+</span></div><span class="cell__cap">octave</span></div>
    <div class="cell"><div class="stepper"><span class="stepper__btn">−</span><span class="stepper__val">128</span><span class="stepper__btn">+</span></div><span class="cell__cap">unison</span></div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Numeric</span><span class="row__lead-name">readable + scrubable</span></div>
    <div class="cell"><div class="num"><span class="num__label">Cutoff</span><span class="num__box">1.42 kHz</span></div></div>
    <div class="cell"><div class="num"><span class="num__label">Decay</span><span class="num__box">3.4 s</span></div></div>
    <div class="cell"><div class="num"><span class="num__label">Mix</span><span class="num__box">−6 dB</span></div></div>
  </div>
</section>

