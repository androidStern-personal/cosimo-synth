        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">0.00</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 15 47.5" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">+0.40</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 37.5 25" transform="rotate(135 50 50)"/>
        <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
      </svg>
      <span class="cell__cap">+1.00</span>
    </div>
  </div>
</section>

<!-- ============================================================
     SLIDERS · HORIZONTAL
     ============================================================ -->
<section class="section section--cream" style="--accent: #C18B4F;">
  <header class="section__head">
    <span class="section__sub">05</span>
    <span class="section__title">Sliders · Horizontal</span>
  </header>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Unipolar · Mix</span><span class="row__lead-name">dry → wet</span></div>
    <div class="cell">
      <div class="slider-h slider-h--uni" style="--val: 0.20;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-dry"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-wet"/></svg></span>
      </div>
      <span class="cell__cap">0.20</span>
    </div>
    <div class="cell">
      <div class="slider-h slider-h--uni" style="--val: 0.50;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-dry"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-wet"/></svg></span>
      </div>
      <span class="cell__cap">0.50</span>
    </div>
    <div class="cell">
      <div class="slider-h slider-h--uni" style="--val: 0.85;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-dry"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-wet"/></svg></span>
      </div>
      <span class="cell__cap">0.85</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Bipolar · Pan</span><span class="row__lead-name">L ◁ → ▷ R</span></div>
    <div class="cell">
      <div class="slider-h slider-h--bi" style="--val: -0.65;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-tri-l"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__center"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-tri-r"/></svg></span>
      </div>
      <span class="cell__cap">−0.65</span>
    </div>
    <div class="cell">
      <div class="slider-h slider-h--bi" style="--val: 0;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-tri-l"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__center"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-tri-r"/></svg></span>
      </div>
      <span class="cell__cap">0.00</span>
    </div>
    <div class="cell">
      <div class="slider-h slider-h--bi" style="--val: 0.40;">
