<section class="section section--cream" style="--accent: #C18B4F;">
  <header class="section__head">
    <span class="section__sub">13</span>
    <span class="section__title">Meters · LEDs · Readouts</span>
  </header>

  <div class="row" style="align-items: flex-start;">
    <div class="row__lead"><span class="row__lead-cap">Vertical meter</span><span class="row__lead-name">filled / segmented</span></div>
    <div class="cell"><div class="meter-v" style="--val: 0.78;"><span class="meter-v__fill"></span></div><span class="cell__cap">−6 dB</span></div>
    <div class="cell"><div class="meter-v" style="--val: 0.52;"><span class="meter-v__fill"></span></div><span class="cell__cap">−12 dB</span></div>
    <div class="cell"><div class="meter-v" style="--val: 0.28;"><span class="meter-v__fill"></span></div><span class="cell__cap">−24 dB</span></div>
    <div class="cell"><div class="meter-v meter-v--seg" style="height:140px;">
      <span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg on"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span>
    </div><span class="cell__cap">segmented</span></div>
  </div>

  <div class="row" style="align-items: flex-start;">
    <div class="row__lead"><span class="row__lead-cap">Horizontal meter</span><span class="row__lead-name">in / GR / out</span></div>
    <div class="cell" style="align-items: stretch;">
      <div class="meter-h" style="--val: 0.86;"><span class="meter-h__fill"></span></div>
      <span class="cell__cap" style="margin-top: 4px;">in</span>
    </div>
    <div class="cell" style="align-items: stretch;">
      <div class="meter-h" style="--val: 0.42;"><span class="meter-h__fill"></span></div>
      <span class="cell__cap" style="margin-top: 4px;">gr</span>
    </div>
    <div class="cell" style="align-items: stretch;">
      <div class="meter-h" style="--val: 0.65;"><span class="meter-h__fill"></span></div>
      <span class="cell__cap" style="margin-top: 4px;">out</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">LED</span><span class="row__lead-name">single · strip</span></div>
    <div class="cell"><span class="led led--on"></span><span class="cell__cap">on</span></div>
    <div class="cell"><span class="led"></span><span class="cell__cap">off</span></div>
    <div class="cell">
      <div class="led-strip">
        <span class="led led--on"></span>
        <span class="led led--on"></span>
        <span class="led led--on"></span>
        <span class="led led--on"></span>
        <span class="led led--on"></span>
        <span class="led"></span>
        <span class="led"></span>
        <span class="led"></span>
      </div>
      <span class="cell__cap">8-step</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead"><span class="row__lead-cap">Readout</span><span class="row__lead-name">large numeric</span></div>
    <div class="cell"><span class="readout">1.42<span class="readout__unit">kHz</span></span><span class="cell__cap">cutoff</span></div>
    <div class="cell"><span class="readout">128<span class="readout__unit">smp</span></span><span class="cell__cap">buffer</span></div>
    <div class="cell"><span class="readout">−6.0<span class="readout__unit">dB</span></span><span class="cell__cap">gain</span></div>
    <div class="cell"><span class="readout">124<span class="readout__unit">bpm</span></span><span class="cell__cap">tempo</span></div>
  </div>
</section>

<!-- ============================================================
     LIVE READOUTS — the only place glow is allowed
     ============================================================ -->
<section class="section section--dark" style="--accent: #FFB14A;">
  <header class="section__head">
    <span class="section__sub">14</span>
    <span class="section__title">Live readouts · glow allowed</span>
  </header>
  <p style="font-family: 'JetBrains Mono', monospace; font-size: 11.5px; line-height: 1.5; color: var(--cream-on-dark-soft); max-width: 720px; margin-bottom: 32px; letter-spacing: 0.04em;">
    The only place the system uses glow. Reserved for live, animated readouts that respond to audio in real time. Static UI never glows.
  </p>

  <div class="live-grid">

    <!-- oscilloscope -->
    <div class="live-card">
      <div class="live-card__head">
        <span class="live-card__title">Oscilloscope</span>
        <span class="live-card__sub">256 samples · 48 kHz</span>
      </div>
      <div class="live-card__body">
        <svg viewBox="0 0 460 120" style="width: 100%; height: 120px;">
          <line x1="0" y1="60" x2="460" y2="60" stroke="currentColor" stroke-width="1" opacity="0.18"/>
          <path class="glow-stroke" d="M0,60 Q12,18 24,60 T48,60 T72,60 Q84,12 96,60 T120,60 Q132,28 144,60 T168,60 Q180,40 192,60 T216,60 Q228,8 240,60 T264,60 T288,60 Q300,30 312,60 T336,60 Q348,16 360,60 T384,60 Q396,38 408,60 T432,60 T460,60"
                fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- spectrum -->
    <div class="live-card">
      <div class="live-card__head">
        <span class="live-card__title">Spectrum</span>
        <span class="live-card__sub">2048 fft · log freq</span>
      </div>
      <div class="live-card__body">
        <svg viewBox="0 0 460 120" style="width: 100%; height: 120px;">
          <g class="glow-fill" fill="currentColor">
            <rect x="6" y="78" width="14" height="42"/>
            <rect x="24" y="62" width="14" height="58"/>
            <rect x="42" y="42" width="14" height="78"/>
            <rect x="60" y="28" width="14" height="92"/>
            <rect x="78" y="14" width="14" height="106"/>
            <rect x="96" y="8" width="14" height="112"/>
            <rect x="114" y="22" width="14" height="98"/>
            <rect x="132" y="34" width="14" height="86"/>
            <rect x="150" y="46" width="14" height="74"/>
            <rect x="168" y="56" width="14" height="64"/>
            <rect x="186" y="66" width="14" height="54"/>
            <rect x="204" y="74" width="14" height="46"/>
            <rect x="222" y="80" width="14" height="40"/>
            <rect x="240" y="84" width="14" height="36"/>
            <rect x="258" y="86" width="14" height="34"/>
            <rect x="276" y="92" width="14" height="28"/>
            <rect x="294" y="94" width="14" height="26"/>
            <rect x="312" y="96" width="14" height="24"/>
            <rect x="330" y="98" width="14" height="22"/>
            <rect x="348" y="100" width="14" height="20"/>
            <rect x="366" y="102" width="14" height="18"/>
            <rect x="384" y="104" width="14" height="16"/>
            <rect x="402" y="106" width="14" height="14"/>
            <rect x="420" y="108" width="14" height="12"/>
            <rect x="438" y="110" width="14" height="10"/>
          </g>
        </svg>
      </div>
    </div>

    <!-- gain reduction meter -->
    <div class="live-card">
      <div class="live-card__head">
        <span class="live-card__title">Gain reduction</span>
        <span class="live-card__sub">−6.2 dB</span>
      </div>
      <div class="live-card__body">
        <div class="meter-h glow-fill" style="--val: 0.42; height: 28px; width: 100%;">
          <span class="meter-h__fill"></span>
        </div>
        <div style="display: flex; justify-content: space-between; margin-top: 6px; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--accent); opacity: 0.65; letter-spacing: 0.08em;">
          <span>0</span><span>−3</span><span>−6</span><span>−12</span><span>−24</span>
        </div>
      </div>
    </div>

    <!-- pitch detector / live readout -->
    <div class="live-card">
      <div class="live-card__head">
        <span class="live-card__title">Pitch · live</span>
        <span class="live-card__sub">A4 · 440.0 Hz</span>
      </div>
      <div class="live-card__body">
        <span class="readout glow-fill" style="font-size: 56px;">A4<span class="readout__unit" style="font-size: 22px;">+0¢</span></span>
        <div class="led-strip glow-fill" style="margin-top: 14px;">
          <span class="led"></span><span class="led"></span><span class="led led--on"></span><span class="led led--on"></span><span class="led led--on"></span><span class="led"></span><span class="led"></span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ============================================================
     PUTTING IT TOGETHER — a small composed example
     ============================================================ -->
<section class="section section--cream" style="--accent: #1A1814;">
  <header class="section__head">
    <span class="section__sub">15</span>
    <span class="section__title">Putting it together · in context</span>
  </header>
</section>

<div class="demo">
  <div class="demo__bar">
    <span class="demo__brand">Cosimo · Voice</span>
    <span class="demo__sub">mk i</span>
    <span class="demo__sep"></span>
    <span class="demo__sub">preset · glass pad / wide</span>
  </div>
  <div class="demo__body">

    <!-- OSC -->
    <section class="demo__col" style="--accent: #FF5FA8; background: var(--cream);">
      <div class="demo__col-title">Oscillator</div>
      <span class="demo__col-sub">wavetable</span>

      <div class="tabs" style="font-size: 18px;">
        <span class="tabs__item tabs__item--on">Wavetable</span>
        <span class="tabs__item">Sample</span>
      </div>

      <div class="demo__big-knobs">
        <div class="demo__big-cell">
          <svg class="knob knob--lg" viewBox="0 0 100 100">
            <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
            <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="48 100" transform="rotate(135 50 50)"/>
          </svg>
          <span class="demo__big-cell-label">Shape</span>
          <span class="demo__big-cell-val">0.65</span>
        </div>
        <div class="demo__big-cell">
          <svg class="knob knob--lg" viewBox="0 0 100 100">
            <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
            <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="0 37.5 18 44.5" transform="rotate(135 50 50)"/>
            <line class="knob__center-tick" x1="50" y1="2" x2="50" y2="14" stroke-width="3"/>
          </svg>
          <span class="demo__big-cell-label">Detune</span>
          <span class="demo__big-cell-val">+0.48</span>
        </div>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 4px;">
        <span class="pill pill--on">Sub</span>
        <span class="pill">FM</span>
        <span class="pill">Noise</span>
      </div>
    </section>

    <!-- FILTER -->
    <section class="demo__col" style="--accent: #5EC6FF; background: var(--cream);">
      <div class="demo__col-title">Filter</div>
      <span class="demo__col-sub">ladder · 24 dB</span>

      <div class="segmented">
        <span class="segmented__item">LP</span>
        <span class="segmented__item segmented__item--on">LP24</span>
        <span class="segmented__item">BP</span>
        <span class="segmented__item">HP</span>
      </div>

      <div class="demo__big-knobs">
        <div class="demo__big-cell">
          <svg class="knob knob--lg" viewBox="0 0 100 100">
            <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
            <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="46 100" transform="rotate(135 50 50)"/>
          </svg>
          <span class="demo__big-cell-label">Cutoff</span>
          <span class="demo__big-cell-val">1.42 kHz</span>
        </div>
        <div class="demo__big-cell">
          <svg class="knob knob--lg" viewBox="0 0 100 100">
            <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
            <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="36 100" transform="rotate(135 50 50)"/>
          </svg>
          <span class="demo__big-cell-label">Reso</span>
          <span class="demo__big-cell-val">0.62</span>
        </div>
      </div>

      <div class="slider-h slider-h--uni" style="--val: 0.62; width: 100%;">
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-wave-lo"/></svg></span>
        <div class="slider-h__bar"><span class="slider-h__track"></span><span class="slider-h__fill"></span><span class="slider-h__handle"></span></div>
        <span class="slider-h__pole"><svg class="glyph"><use href="#g-wave-hi"/></svg></span>
      </div>
      <span style="font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--accent); opacity: 0.65; margin-top: -8px; letter-spacing: 0.08em;">Track · key follow</span>
    </section>

    <!-- ENV -->
    <section class="demo__col" style="--accent: #6CF3A9; background: var(--cream);">
      <div class="demo__col-title">Envelope</div>
      <span class="demo__col-sub">ADSR · linear</span>

      <div class="env" style="height: 100px;">
        <svg viewBox="0 0 400 90" preserveAspectRatio="none">
          <line x1="0" y1="80" x2="400" y2="80" stroke="currentColor" stroke-width="1" opacity="0.18" stroke-linecap="round"/>
          <path class="env__line" d="M0,80 L56,8 L112,40 L260,40 L400,80"/>
          <circle class="env__node" cx="0" cy="80" r="4"/>
          <circle class="env__node" cx="56" cy="8" r="5"/>
          <circle class="env__node" cx="112" cy="40" r="5"/>
          <circle class="env__node" cx="260" cy="40" r="5"/>
          <circle class="env__node" cx="400" cy="80" r="4"/>
        </svg>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 14px; align-items: flex-start;">
        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
          <div class="slider-v slider-v--uni" style="--val: 0.08; height: 130px; gap: 6px;">
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-lg"/></svg></span>
            <div class="slider-v__bar"><span class="slider-v__track"></span><span class="slider-v__fill"></span><span class="slider-v__handle"></span></div>
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-sm"/></svg></span>
          </div>
          <span class="demo__big-cell-label" style="font-size: 10px;">A</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
          <div class="slider-v slider-v--uni" style="--val: 0.42; height: 130px; gap: 6px;">
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-lg"/></svg></span>
            <div class="slider-v__bar"><span class="slider-v__track"></span><span class="slider-v__fill"></span><span class="slider-v__handle"></span></div>
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-sm"/></svg></span>
          </div>
          <span class="demo__big-cell-label" style="font-size: 10px;">D</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
          <div class="slider-v slider-v--uni" style="--val: 0.62; height: 130px; gap: 6px;">
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-bar-hi"/></svg></span>
            <div class="slider-v__bar"><span class="slider-v__track"></span><span class="slider-v__fill"></span><span class="slider-v__handle"></span></div>
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-bar-lo"/></svg></span>
          </div>
          <span class="demo__big-cell-label" style="font-size: 10px;">S</span>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
          <div class="slider-v slider-v--uni" style="--val: 0.50; height: 130px; gap: 6px;">
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-lg"/></svg></span>
            <div class="slider-v__bar"><span class="slider-v__track"></span><span class="slider-v__fill"></span><span class="slider-v__handle"></span></div>
            <span class="slider-v__pole"><svg class="glyph glyph--sm"><use href="#g-dot-sm"/></svg></span>
          </div>
          <span class="demo__big-cell-label" style="font-size: 10px;">R</span>
        </div>
      </div>
    </section>

  </div>
</div>

<!-- ============================================================
     PALETTE
     ============================================================ -->
<section class="section section--cream">
  <header class="section__head">
    <span class="section__sub">16</span>
    <span class="section__title">Accent palette</span>
  </header>
  <div class="palette">
    <div class="swatch"><span class="swatch__chip" style="--c: #FF5FA8;"></span><span class="swatch__body"><span class="swatch__name">Carmine</span><span class="swatch__hex">#FF5FA8</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #5EC6FF;"></span><span class="swatch__body"><span class="swatch__name">Cyan</span><span class="swatch__hex">#5EC6FF</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #6CF3A9;"></span><span class="swatch__body"><span class="swatch__name">Mint</span><span class="swatch__hex">#6CF3A9</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #FFB14A;"></span><span class="swatch__body"><span class="swatch__name">Amber</span><span class="swatch__hex">#FFB14A</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #FF6E3F;"></span><span class="swatch__body"><span class="swatch__name">Ember</span><span class="swatch__hex">#FF6E3F</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #B58BFF;"></span><span class="swatch__body"><span class="swatch__name">Iris</span><span class="swatch__hex">#B58BFF</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #2E8B7B;"></span><span class="swatch__body"><span class="swatch__name">Pine</span><span class="swatch__hex">#2E8B7B</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #C18B4F;"></span><span class="swatch__body"><span class="swatch__name">Tobacco</span><span class="swatch__hex">#C18B4F</span></span></div>
    <div class="swatch"><span class="swatch__chip" style="--c: #E94F8E;"></span><span class="swatch__body"><span class="swatch__name">Rose</span><span class="swatch__hex">#E94F8E</span></span></div>
  </div>
</section>

<footer class="foot">
  <span style="color: var(--ink); font-weight: 700;">Cosimo</span>
  <span class="dot"></span>
  <span>component library · v 0.3 · pure flat</span>
  <span class="dot"></span>
  <span>2026.04.29</span>
</footer>

</body>
</html>
