<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Cosimo · Component Library</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />
<link rel="stylesheet" href="styles.css" />
</head>
<body>

<!-- ============================================================
     POLE GLYPH SPRITE — referenced by sliders & knobs via <use>
     Each represents what one pole of a control maps to.
     ============================================================ -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- mix · dry / wet -->
    <symbol id="g-dry" viewBox="0 0 16 16">
      <circle cx="8" cy="8" r="3.6" fill="none" stroke="currentColor" stroke-width="1.6"/>
    </symbol>
    <symbol id="g-wet" viewBox="0 0 16 16">
      <circle cx="8" cy="8" r="5" fill="currentColor"/>
    </symbol>
    <!-- pan · L / R -->
    <symbol id="g-tri-l" viewBox="0 0 16 16">
      <path d="M11 3.5 L11 12.5 L3.5 8 Z" fill="currentColor"/>
    </symbol>
    <symbol id="g-tri-r" viewBox="0 0 16 16">
      <path d="M5 3.5 L5 12.5 L12.5 8 Z" fill="currentColor"/>
    </symbol>
    <!-- tune · down / up -->
    <symbol id="g-tri-d" viewBox="0 0 16 16">
      <path d="M3.5 5 L12.5 5 L8 12.5 Z" fill="currentColor"/>
    </symbol>
    <symbol id="g-tri-u" viewBox="0 0 16 16">
      <path d="M3.5 11 L12.5 11 L8 3.5 Z" fill="currentColor"/>
    </symbol>
    <!-- frequency · slow / fast wave -->
    <symbol id="g-wave-lo" viewBox="0 0 16 16">
      <path d="M1 8 Q4.5 1.5 8 8 T15 8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </symbol>
    <symbol id="g-wave-hi" viewBox="0 0 16 16">
      <path d="M0.5 8 Q1.75 4 3 8 T5.5 8 T8 8 T10.5 8 T13 8 T15.5 8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </symbol>
    <!-- level · single short bar / three ascending bars -->
    <symbol id="g-bar-lo" viewBox="0 0 16 16">
      <rect x="2" y="10.5" width="3" height="3.5" rx="0.6" fill="currentColor"/>
    </symbol>
    <symbol id="g-bar-hi" viewBox="0 0 16 16">
      <rect x="2" y="10.5" width="3" height="3.5" rx="0.6" fill="currentColor"/>
      <rect x="6.5" y="7" width="3" height="7" rx="0.6" fill="currentColor"/>
      <rect x="11" y="2.5" width="3" height="11.5" rx="0.6" fill="currentColor"/>
    </symbol>
    <!-- amount · small dot / big disc -->
    <symbol id="g-dot-sm" viewBox="0 0 16 16">
      <circle cx="8" cy="8" r="1.6" fill="currentColor"/>
    </symbol>
    <symbol id="g-dot-lg" viewBox="0 0 16 16">
      <circle cx="8" cy="8" r="5" fill="currentColor"/>
    </symbol>
    <!-- math · minus / plus -->
    <symbol id="g-minus" viewBox="0 0 16 16">
      <rect x="3" y="7" width="10" height="2" rx="1" fill="currentColor"/>
    </symbol>
    <symbol id="g-plus" viewBox="0 0 16 16">
      <rect x="3" y="7" width="10" height="2" rx="1" fill="currentColor"/>
      <rect x="7" y="3" width="2" height="10" rx="1" fill="currentColor"/>
    </symbol>
  </defs>
</svg>

<header class="head">
  <h1>Cosimo<span class="accent-mark"></span></h1>
  <span class="head__meta">
    <span>Component library · v 0.3</span>
    <span>Flat · single accent · two backgrounds</span>
    <span>2026.04.29</span>
  </span>
</header>

<p class="intro">
  Pure flat. <strong>Two background colors only</strong>: black and a warm cream. Within each logical section <strong>one accent color does all the work</strong>. No gradients on controls. No drop shadows. No glow on static design; glow is reserved for live, animated readouts (last section). Every control is the same control on both surfaces.
</p>

<!-- ============================================================
     KNOBS — UNIPOLAR
     ============================================================ -->
<section class="section section--cream" style="--accent: #C18B4F;">
  <header class="section__head">
    <span class="section__sub">01</span>
    <span class="section__title">Knobs · Unipolar</span>
  </header>

  <div class="row">
    <div class="row__lead">
      <span class="row__lead-cap">Sizes</span>
      <span class="row__lead-name">xs / sm / md / lg / xl</span>
    </div>

    <div class="cell">
      <svg class="knob knob--xs" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="22 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.30</span>
    </div>
    <div class="cell">
      <svg class="knob knob--sm" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="38 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.50</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="48 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.65</span>
    </div>
    <div class="cell">
      <svg class="knob knob--lg" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="58 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.78</span>
    </div>
    <div class="cell">
      <svg class="knob knob--xl" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="68 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.90</span>
    </div>
  </div>

  <div class="row">
    <div class="row__lead">
      <span class="row__lead-cap">Range</span>
      <span class="row__lead-name">cutoff · volume · drive</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">min</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="19 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.25</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="37.5 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.50</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="56 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">0.75</span>
    </div>
    <div class="cell">
      <svg class="knob knob--md" viewBox="0 0 100 100">
        <circle class="knob__track" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
        <circle class="knob__value" cx="50" cy="50" r="40" pathLength="100" stroke-width="9" stroke-dasharray="75 100" transform="rotate(135 50 50)"/>
      </svg>
      <span class="cell__cap">max</span>
    </div>
  </div>
</section>

