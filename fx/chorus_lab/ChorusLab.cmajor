namespace choruslab
{
    let kPi = 3.14159265358979323846f;
    let kFifthRatio = 1.4983070768766815f;
    let kGroupCount = 3;
    let kInnerPairCount = 3;
    let kChannelCount = 2;
    let kDiffusionStageCount = 4;
    let kMaxChorusDelayMs = 96.0f;
    let kMaxDiffusionDelayMs = 72.0f;
    let kMaxShimmerGrainMs = 80.0f;

    float32 lerp (float32 start, float32 end, float32 amount)
    {
        return start + ((end - start) * amount);
    }

    float32 catmullRom (float32 p0, float32 p1, float32 p2, float32 p3, float32 t)
    {
        return p1 + 0.5f * t * ((p2 - p0) + t * ((2.0f * p0 - 5.0f * p1 + 4.0f * p2 - p3)
               + t * (-p0 + 3.0f * p1 - 3.0f * p2 + p3)));
    }

    float32 wrap01 (float32 value)
    {
        return std::intrinsics::wrap (value, 1.0f);
    }

    float32 hann (float32 phase)
    {
        return 0.5f - 0.5f * std::intrinsics::cos (2.0f * kPi * phase);
    }

    float32 softClip (float32 value)
    {
        let magnitude = std::intrinsics::abs (value);
        return value / (1.0f + magnitude);
    }

    float32 softClipLarge (float32 value, float32 drive)
    {
        let scaled = value * drive * 0.125f;
        return softClip (scaled) * 8.0f;
    }

    float32 coefficientForCutoff (float32 sampleRate, float32 cutoffHz)
    {
        let clampedCutoff = std::intrinsics::clamp (cutoffHz, 10.0f, sampleRate * 0.45f);
        return 1.0f - std::intrinsics::exp ((-2.0f * kPi * clampedCutoff) / sampleRate);
    }
}

processor ChorusLab [[ main ]]
{
    input stream float32<2> in;
    output stream float32<2> out;

    input value float32 mix                  [[ name: "Mix",               group: "Output", min: 0.0f,   max: 100.0f, init: 50.0f,  unit: "%",   rampFrames: 256 ]];

    input value float32 voices              [[ name: "Voices",            group: "Chorus", min: 1.0f,   max: 3.0f,   init: 3.0f,   unit: "",    rampFrames: 256 ]];
    input value float32 rateHz              [[ name: "Rate",              group: "Chorus", min: 0.02f,  max: 6.0f,   init: 0.33f,  unit: "Hz",  rampFrames: 256 ]];
    input value float32 delayAms            [[ name: "Delay A",           group: "Chorus", min: 2.0f,   max: 30.0f,  init: 8.0f,   unit: "ms",  rampFrames: 256 ]];
    input value float32 delayBms            [[ name: "Delay B",           group: "Chorus", min: 2.0f,   max: 30.0f,  init: 14.0f,  unit: "ms",  rampFrames: 256 ]];
    input value float32 modDepthMs          [[ name: "Mod Depth",         group: "Chorus", min: 0.0f,   max: 30.0f,  init: 7.0f,   unit: "ms",  rampFrames: 256 ]];
    input value float32 driftMs             [[ name: "Drift",             group: "Chorus", min: 0.0f,   max: 4.0f,   init: 0.4f,   unit: "ms",  rampFrames: 256 ]];

    input value float32 groupPhaseSpread    [[ name: "Group Spread",      group: "Phase",  min: 0.0f,   max: 0.5f,   init: 0.25f,  unit: "cyc", rampFrames: 256 ]];
    input value float32 rightPhaseOffset    [[ name: "Right Offset",      group: "Phase",  min: 0.0f,   max: 0.5f,   init: 0.25f,  unit: "cyc", rampFrames: 256 ]];
    input value float32 innerPairOffset     [[ name: "Inner Pair Offset", group: "Phase",  min: 0.0f,   max: 1.0f,   init: 0.5f,   unit: "cyc", rampFrames: 256 ]];

    input value float32 feedback            [[ name: "Feedback",          group: "Loop",   min: -95.0f, max: 95.0f,  init: 40.0f,  unit: "%",   rampFrames: 256 ]];
    input value float32 loopHighpassHz      [[ name: "Loop HP",           group: "Loop",   min: 20.0f,  max: 1200.0f, init: 90.0f,  unit: "Hz",  rampFrames: 256 ]];
    input value float32 loopLowpassHz       [[ name: "Loop LP",           group: "Loop",   min: 800.0f, max: 18000.0f, init: 6400.0f, unit: "Hz", rampFrames: 256 ]];
    input value float32 drive               [[ name: "Drive",             group: "Loop",   min: 0.5f,   max: 4.0f,   init: 1.35f,  unit: "x",   rampFrames: 256 ]];

    input value float32 diffuse             [[ name: "Diffuse",           group: "Bloom",  min: 0.0f,   max: 100.0f, init: 24.0f,  unit: "%",   rampFrames: 256 ]];
    input value float32 diffuseDelayMs      [[ name: "Diffuse Delay",     group: "Bloom",  min: 2.0f,   max: 40.0f,  init: 7.0f,   unit: "ms",  rampFrames: 256 ]];
    input value float32 diffuseMod          [[ name: "Diffuse Mod",       group: "Bloom",  min: 0.0f,   max: 100.0f, init: 22.0f,  unit: "%",   rampFrames: 256 ]];
    input value float32 diffuseReturnGain   [[ name: "Diffuse Return",    group: "Bloom",  min: 0.0f,   max: 400.0f, init: 100.0f, unit: "%",   rampFrames: 256 ]];
    input value float32 shimmer             [[ name: "Shimmer",           group: "Bloom",  min: 0.0f,   max: 100.0f, init: 16.0f,  unit: "%",   rampFrames: 256 ]];
    input value float32 shimmerReturnGain   [[ name: "Shimmer Return",    group: "Bloom",  min: 0.0f,   max: 400.0f, init: 100.0f, unit: "%",   rampFrames: 256 ]];
    input value float32 shimmerGrainMs      [[ name: "Shimmer Grain",     group: "Bloom",  min: 18.0f,  max: 80.0f,  init: 42.0f,  unit: "ms",  rampFrames: 256 ]];
    input value float32 shimmerTone         [[ name: "Shimmer Tone",      group: "Bloom",  min: 0.0f,   max: 100.0f, init: 58.0f,  unit: "%",   rampFrames: 256 ]];
    input value bool alternatePitchRoles    [[ name: "Alt Pitch Roles",   group: "Bloom",  init: false, boolean ]];
    input value bool shimmerSolo            [[ name: "Shimmer Solo",      group: "Bloom",  init: false, boolean ]];

    let chorusBufferSize = int (processor.maxFrequency * choruslab::kMaxChorusDelayMs * 0.001f) + 8;
    let diffusionBufferSize = int (processor.maxFrequency * choruslab::kMaxDiffusionDelayMs * 0.001f) + 8;
    let shimmerBufferSize = int (processor.maxFrequency * choruslab::kMaxShimmerGrainMs * 0.001f) + 512;

    float32[choruslab::kGroupCount, choruslab::kInnerPairCount, choruslab::kChannelCount, chorusBufferSize] delayBuffers;
    wrap<chorusBufferSize>[choruslab::kGroupCount, choruslab::kInnerPairCount, choruslab::kChannelCount] delayWritePositions;

    float32[choruslab::kGroupCount, choruslab::kInnerPairCount, choruslab::kChannelCount] loopHighpassState;
    float32[choruslab::kGroupCount, choruslab::kInnerPairCount, choruslab::kChannelCount] loopLowpassState;
    float32[choruslab::kGroupCount, choruslab::kInnerPairCount, choruslab::kChannelCount] regenInjectionState;

    float32[choruslab::kGroupCount, choruslab::kChannelCount, choruslab::kDiffusionStageCount, diffusionBufferSize] diffusionBuffers;
    wrap<diffusionBufferSize>[choruslab::kGroupCount, choruslab::kChannelCount, choruslab::kDiffusionStageCount] diffusionWritePositions;

    float32[choruslab::kGroupCount, choruslab::kChannelCount, shimmerBufferSize] shimmerBuffers;
    wrap<shimmerBufferSize>[choruslab::kGroupCount, choruslab::kChannelCount] shimmerWritePositions;
    float32[choruslab::kGroupCount, choruslab::kChannelCount] shimmerLowpassState;

    std::random::RNG[choruslab::kGroupCount, choruslab::kInnerPairCount] driftRng;
    float32[choruslab::kGroupCount, choruslab::kInnerPairCount] driftValue;
    float32[choruslab::kGroupCount, choruslab::kInnerPairCount] driftTarget;
    int32[choruslab::kGroupCount, choruslab::kInnerPairCount] driftCounter;

    float32 lfoPhase;
    float32[choruslab::kGroupCount] shimmerPhase;

    void init()
    {
        for (wrap<choruslab::kGroupCount> group)
        {
            shimmerPhase[group] = float32 (int32 (group)) / float32 (choruslab::kGroupCount);

            for (wrap<choruslab::kInnerPairCount> innerPair)
            {
                let seed = 1001L
                         + int64 (processor.id) * 37L
                         + int64 (int32 (group)) * 149L
                         + int64 (int32 (innerPair)) * 311L;
                driftRng[group, innerPair].seed (seed);
                driftTarget[group, innerPair] = driftRng[group, innerPair].getBipolar();
                driftValue[group, innerPair] = driftTarget[group, innerPair] * 0.18f;
                driftCounter[group, innerPair] = int32 (processor.frequency * (0.18f + 0.09f * float32 (int32 (group) + int32 (innerPair) + 1)));
            }
        }
    }

    float32 readDelaySample (wrap<choruslab::kGroupCount> group,
                             wrap<choruslab::kInnerPairCount> innerPair,
                             wrap<choruslab::kChannelCount> channel,
                             float32 delaySamples)
    {
        let clampedDelay = std::intrinsics::clamp (delaySamples, 2.0f, float32 (chorusBufferSize - 4));
        let writeIndex = int32 (delayWritePositions[group, innerPair, channel]);
        let readPos = std::intrinsics::wrap (float32 (writeIndex) - clampedDelay, float32 (chorusBufferSize));
        let index1 = int32 (std::intrinsics::floor (readPos));
        let fraction = readPos - float32 (index1);
        let i0 = wrap<chorusBufferSize> (index1 + chorusBufferSize - 1);
        let i1 = wrap<chorusBufferSize> (index1);
        let i2 = wrap<chorusBufferSize> (index1 + 1);
        let i3 = wrap<chorusBufferSize> (index1 + 2);

        return choruslab::catmullRom (
            delayBuffers[group, innerPair, channel, i0],
            delayBuffers[group, innerPair, channel, i1],
            delayBuffers[group, innerPair, channel, i2],
            delayBuffers[group, innerPair, channel, i3],
            fraction
        );
    }

    void writeDelaySample (wrap<choruslab::kGroupCount> group,
                           wrap<choruslab::kInnerPairCount> innerPair,
                           wrap<choruslab::kChannelCount> channel,
                           float32 sample)
    {
        let writeIndex = delayWritePositions[group, innerPair, channel];
        delayBuffers[group, innerPair, channel, writeIndex] = sample;
        delayWritePositions[group, innerPair, channel] = wrap<chorusBufferSize> (int32 (writeIndex) + 1);
    }

    float32 readDiffusionSample (wrap<choruslab::kGroupCount> group,
                                 wrap<choruslab::kChannelCount> channel,
                                 wrap<choruslab::kDiffusionStageCount> stage,
                                 float32 delaySamples)
    {
        let clampedDelay = std::intrinsics::clamp (delaySamples, 2.0f, float32 (diffusionBufferSize - 4));
        let writeIndex = int32 (diffusionWritePositions[group, channel, stage]);
        let readPos = std::intrinsics::wrap (float32 (writeIndex) - clampedDelay, float32 (diffusionBufferSize));
        let index1 = int32 (std::intrinsics::floor (readPos));
        let fraction = readPos - float32 (index1);
        let i0 = wrap<diffusionBufferSize> (index1 + diffusionBufferSize - 1);
        let i1 = wrap<diffusionBufferSize> (index1);
        let i2 = wrap<diffusionBufferSize> (index1 + 1);
        let i3 = wrap<diffusionBufferSize> (index1 + 2);

        return choruslab::catmullRom (
            diffusionBuffers[group, channel, stage, i0],
            diffusionBuffers[group, channel, stage, i1],
            diffusionBuffers[group, channel, stage, i2],
            diffusionBuffers[group, channel, stage, i3],
            fraction
        );
    }

    void writeDiffusionSample (wrap<choruslab::kGroupCount> group,
                               wrap<choruslab::kChannelCount> channel,
                               wrap<choruslab::kDiffusionStageCount> stage,
                               float32 sample)
    {
        let writeIndex = diffusionWritePositions[group, channel, stage];
        diffusionBuffers[group, channel, stage, writeIndex] = sample;
        diffusionWritePositions[group, channel, stage] = wrap<diffusionBufferSize> (int32 (writeIndex) + 1);
    }

    float32 readShimmerSample (wrap<choruslab::kGroupCount> group,
                               wrap<choruslab::kChannelCount> channel,
                               float32 delaySamples)
    {
        let clampedDelay = std::intrinsics::clamp (delaySamples, 2.0f, float32 (shimmerBufferSize - 4));
        let writeIndex = int32 (shimmerWritePositions[group, channel]);
        let readPos = std::intrinsics::wrap (float32 (writeIndex) - clampedDelay, float32 (shimmerBufferSize));
        let index1 = int32 (std::intrinsics::floor (readPos));
        let fraction = readPos - float32 (index1);
        let i0 = wrap<shimmerBufferSize> (index1 + shimmerBufferSize - 1);
        let i1 = wrap<shimmerBufferSize> (index1);
        let i2 = wrap<shimmerBufferSize> (index1 + 1);
        let i3 = wrap<shimmerBufferSize> (index1 + 2);

        return choruslab::catmullRom (
            shimmerBuffers[group, channel, i0],
            shimmerBuffers[group, channel, i1],
            shimmerBuffers[group, channel, i2],
            shimmerBuffers[group, channel, i3],
            fraction
        );
    }

    float32 updateDrift (wrap<choruslab::kGroupCount> group,
                         wrap<choruslab::kInnerPairCount> innerPair)
    {
        let minimumHold = int32 (processor.frequency * 0.18f);
        let maximumHold = int32 (processor.frequency * 0.72f);
        var counter = driftCounter[group, innerPair] - 1;

        if (counter <= 0)
        {
            let holdRange = maximumHold - minimumHold;
            counter = minimumHold + int32 (float32 (holdRange) * driftRng[group, innerPair].getUnipolar());
            driftTarget[group, innerPair] = driftRng[group, innerPair].getBipolar();
        }

        driftCounter[group, innerPair] = counter;
        driftValue[group, innerPair] += (driftTarget[group, innerPair] - driftValue[group, innerPair]) * 0.00065f;
        return driftValue[group, innerPair];
    }

    float32 baseDelayForLane (wrap<choruslab::kGroupCount> group,
                              wrap<choruslab::kInnerPairCount> innerPair,
                              float32 delayA,
                              float32 delayB,
                              int32 activeGroups)
    {
        let innerT = float32 (int32 (innerPair)) / float32 (choruslab::kInnerPairCount - 1);
        let groupT = activeGroups <= 1 ? 0.5f
                                       : float32 (int32 (group)) / float32 (activeGroups - 1);
        let centeredInner = innerT - 0.5f;
        let centeredGroup = groupT - 0.5f;
        let blendedT = std::intrinsics::clamp (
            0.5f
            + (centeredInner * 0.72f)
            + (centeredGroup * 0.28f)
            + (centeredInner * centeredGroup * 0.26f),
            0.0f,
            1.0f
        );
        let curvedT = blendedT * blendedT * (3.0f - 2.0f * blendedT);
        return choruslab::lerp (delayA, delayB, curvedT);
    }

    float32 colorLoopWrite (wrap<choruslab::kGroupCount> group,
                            wrap<choruslab::kInnerPairCount> innerPair,
                            wrap<choruslab::kChannelCount> channel,
                            float32 writeRaw,
                            float32 lowCoeff,
                            float32 highCoeff,
                            float32 driveAmount)
    {
        let saturated = choruslab::softClipLarge (writeRaw, driveAmount);
        let lowPassed = loopLowpassState[group, innerPair, channel]
                      + lowCoeff * (saturated - loopLowpassState[group, innerPair, channel]);
        loopLowpassState[group, innerPair, channel] = lowPassed;

        let highpassLow = loopHighpassState[group, innerPair, channel]
                        + highCoeff * (lowPassed - loopHighpassState[group, innerPair, channel]);
        loopHighpassState[group, innerPair, channel] = highpassLow;

        return lowPassed - highpassLow;
    }

    float32 filterShimmerReturn (wrap<choruslab::kGroupCount> group,
                                 wrap<choruslab::kChannelCount> channel,
                                 float32 inputSample,
                                 float32 tone01)
    {
        let shimmerCutoff = choruslab::lerp (3200.0f, 9800.0f, tone01);
        let coefficient = choruslab::coefficientForCutoff (float32 (processor.frequency), shimmerCutoff);
        let current = shimmerLowpassState[group, channel]
                    + coefficient * (inputSample - shimmerLowpassState[group, channel]);
        shimmerLowpassState[group, channel] = current;
        return current;
    }

    float32 processAllpassStage (wrap<choruslab::kGroupCount> group,
                                 wrap<choruslab::kChannelCount> channel,
                                 wrap<choruslab::kDiffusionStageCount> stage,
                                 float32 inputSample,
                                 float32 baseDelaySamples,
                                 float32 amount01,
                                 float32 modAmount01)
    {
        let stageIndex = float32 (int32 (stage));
        let stageScale = 0.42f + (stageIndex * 0.28f);
        let modRateScale = 0.37f + (stageIndex * 0.16f);
        let delayMod = std::intrinsics::sin (
            2.0f * choruslab::kPi
            * ((lfoPhase * modRateScale)
               + stageIndex * 0.17f
               + float32 (int32 (group)) * 0.19f
               + float32 (int32 (channel)) * 0.13f)
        );
        let delaySamples = 4.0f
                         + (baseDelaySamples * stageScale)
                         + (baseDelaySamples * 0.18f * amount01 * modAmount01 * delayMod);
        let gain = 0.22f + amount01 * 0.42f;
        let delayed = readDiffusionSample (group, channel, stage, delaySamples);
        let outputSample = delayed - (gain * inputSample);
        let writeValue = inputSample + (gain * outputSample);

        writeDiffusionSample (group, channel, stage, writeValue);
        return outputSample;
    }

    float32 processDiffusion (wrap<choruslab::kGroupCount> group,
                              wrap<choruslab::kChannelCount> channel,
                              float32 inputSample,
                              float32 baseDelaySamples,
                              float32 amount01,
                              float32 modAmount01)
    {
        if (amount01 <= 0.0001f)
            return inputSample;

        var current = inputSample;

        for (wrap<choruslab::kDiffusionStageCount> stage)
            current = processAllpassStage (group, channel, stage, current, baseDelaySamples, amount01, modAmount01);

        return current;
    }

    float32 processShimmer (wrap<choruslab::kGroupCount> group,
                            wrap<choruslab::kChannelCount> channel,
                            float32 inputSample,
                            float32 grainSamples,
                            float32 pitchRatio)
    {
        let writeIndex = shimmerWritePositions[group, channel];
        shimmerBuffers[group, channel, writeIndex] = inputSample;
        shimmerWritePositions[group, channel] = wrap<shimmerBufferSize> (int32 (writeIndex) + 1);

        let minDelaySamples = 48.0f;
        let phaseA = shimmerPhase[group];
        let phaseB = choruslab::wrap01 (shimmerPhase[group] + 0.5f);
        let sweepSamples = grainSamples * std::intrinsics::max (0.0f, pitchRatio - 1.0f);
        let delayA = minDelaySamples + ((1.0f - phaseA) * sweepSamples);
        let delayB = minDelaySamples + ((1.0f - phaseB) * sweepSamples);
        let windowA = choruslab::hann (phaseA);
        let windowB = choruslab::hann (phaseB);
        let sampleA = readShimmerSample (group, channel, delayA);
        let sampleB = readShimmerSample (group, channel, delayB);

        return (sampleA * windowA + sampleB * windowB)
             / std::intrinsics::max (0.0001f, windowA + windowB);
    }

    void main()
    {
        loop
        {
            let sampleRate = float32 (processor.frequency);
            let dry = in;

            let mix01 = std::intrinsics::clamp (mix * 0.01f, 0.0f, 1.0f);
            let activeGroups = int32 (std::intrinsics::clamp (std::intrinsics::floor (voices + 0.5f), 1.0f, float32 (choruslab::kGroupCount)));
            let delayA = std::intrinsics::clamp (delayAms * sampleRate * 0.001f, 3.0f, float32 (chorusBufferSize - 8));
            let delayB = std::intrinsics::clamp (delayBms * sampleRate * 0.001f, 3.0f, float32 (chorusBufferSize - 8));
            let modDepthSamples = std::intrinsics::clamp (modDepthMs * sampleRate * 0.001f, 0.0f, sampleRate * 0.030f);
            let driftDepthSamples = std::intrinsics::clamp (driftMs * sampleRate * 0.001f, 0.0f, sampleRate * 0.008f);

            let rightOffset = std::intrinsics::clamp (rightPhaseOffset, 0.0f, 0.5f);
            let innerOffset = std::intrinsics::clamp (innerPairOffset, 0.0f, 1.0f);
            let groupSpread = std::intrinsics::clamp (groupPhaseSpread, 0.0f, 0.5f);

            let feedback01 = std::intrinsics::clamp (feedback * 0.01f, -0.95f, 0.95f);
            let feedbackMagnitude = std::intrinsics::abs (feedback01);
            let hpCutoff = std::intrinsics::clamp (loopHighpassHz, 20.0f, sampleRate * 0.20f);
            let lpCutoff = std::intrinsics::clamp (std::intrinsics::max (loopLowpassHz, hpCutoff + 10.0f), hpCutoff + 10.0f, sampleRate * 0.45f);
            let lowCoeff = choruslab::coefficientForCutoff (sampleRate, lpCutoff);
            let highCoeff = choruslab::coefficientForCutoff (sampleRate, hpCutoff);
            let driveAmount = std::intrinsics::clamp (drive, 0.5f, 4.0f);

            let diffuse01 = std::intrinsics::clamp (diffuse * 0.01f, 0.0f, 1.0f);
            let diffuseDelaySamples = std::intrinsics::clamp (diffuseDelayMs * sampleRate * 0.001f, 4.0f, float32 (diffusionBufferSize - 8));
            let diffuseMod01 = std::intrinsics::clamp (diffuseMod * 0.01f, 0.0f, 1.0f);
            let diffuseReturnGain01 = std::intrinsics::max (diffuseReturnGain * 0.01f, 0.0f);
            let shimmer01 = std::intrinsics::clamp (shimmer * 0.01f, 0.0f, 1.0f);
            let shimmerReturnGain01 = std::intrinsics::max (shimmerReturnGain * 0.01f, 0.0f);
            let shimmerTone01 = std::intrinsics::clamp (shimmerTone * 0.01f, 0.0f, 1.0f);
            let shimmerGrainSamples = std::intrinsics::clamp (shimmerGrainMs * sampleRate * 0.001f, sampleRate * 0.018f, float32 (shimmerBufferSize - 256));

            let dryGain = std::intrinsics::cos (0.5f * choruslab::kPi * mix01);
            let wetGain = std::intrinsics::sin (0.5f * choruslab::kPi * mix01);

            var chorusWetLeft = 0.0f;
            var chorusWetRight = 0.0f;
            var shimmerSoloLeft = 0.0f;
            var shimmerSoloRight = 0.0f;

            for (wrap<choruslab::kGroupCount> group)
            {
                if (int32 (group) >= activeGroups)
                    continue;

                let groupPhaseT = activeGroups <= 1 ? 0.5f
                                                    : float32 (int32 (group)) / float32 (activeGroups - 1);
                let groupPhaseOffset = (groupPhaseT - 0.5f) * groupSpread;

                var groupWetLeft = 0.0f;
                var groupWetRight = 0.0f;
                var groupLoopLeft = 0.0f;
                var groupLoopRight = 0.0f;

                for (wrap<choruslab::kInnerPairCount> innerPair)
                {
                    let baseDelay = baseDelayForLane (group, innerPair, delayA, delayB, activeGroups);
                    let drift = updateDrift (group, innerPair);
                    let driftOffset = drift * driftDepthSamples;

                    for (wrap<choruslab::kChannelCount> channel)
                    {
                        let channelPhaseOffset = channel == 0 ? 0.0f : rightOffset;
                        let innerPhaseT = float32 (int32 (innerPair)) / float32 (choruslab::kInnerPairCount - 1);
                        let pairPhaseOffset = (innerPhaseT - 0.5f) * innerOffset;
                        let phase = choruslab::wrap01 (lfoPhase + groupPhaseOffset + channelPhaseOffset + pairPhaseOffset);
                        let mod = std::intrinsics::sin (2.0f * choruslab::kPi * phase) * 0.5f + 1.0f;
                        let delaySamples = std::intrinsics::clamp (
                            baseDelay + (modDepthSamples * mod) + driftOffset,
                            3.0f,
                            float32 (chorusBufferSize - 8)
                        );

                        let delayed = readDelaySample (group, innerPair, channel, delaySamples);
                        let writeRaw = dry[channel]
                                      + regenInjectionState[group, innerPair, channel]
                                      + delayed * feedback01;
                        let filteredWrite = colorLoopWrite (group, innerPair, channel, writeRaw, lowCoeff, highCoeff, driveAmount);
                        writeDelaySample (group, innerPair, channel, filteredWrite);

                        if (channel == 0)
                        {
                            groupWetLeft += delayed / float32 (choruslab::kInnerPairCount);
                            groupLoopLeft += filteredWrite / float32 (choruslab::kInnerPairCount);
                        }
                        else
                        {
                            groupWetRight += delayed / float32 (choruslab::kInnerPairCount);
                            groupLoopRight += filteredWrite / float32 (choruslab::kInnerPairCount);
                        }
                    }
                }

                chorusWetLeft += groupWetLeft;
                chorusWetRight += groupWetRight;
                let fieldIndex = float32 (int32 (group));
                let fieldDiffuseDelaySamples = std::intrinsics::clamp (
                    diffuseDelaySamples * (0.82f + 0.18f * fieldIndex),
                    4.0f,
                    float32 (diffusionBufferSize - 8)
                );
                let fieldDiffuseMod01 = std::intrinsics::clamp (diffuseMod01 * (0.90f + 0.08f * fieldIndex), 0.0f, 1.0f);
                let fieldShimmerGrainSamples = std::intrinsics::clamp (
                    shimmerGrainSamples * (0.90f + 0.07f * fieldIndex),
                    sampleRate * 0.018f,
                    float32 (shimmerBufferSize - 256)
                );
                let fieldPitchRatio = alternatePitchRoles
                    ? (group == 0 ? 1.0f
                                  : (group == 1 ? choruslab::kFifthRatio
                                                : 2.0f))
                    : 2.0f;
                let fieldShimmerSend = shimmer01 * feedbackMagnitude * (0.82f + 0.11f * fieldIndex);

                let diffusedLeft = processDiffusion (group, 0, groupLoopLeft, fieldDiffuseDelaySamples, diffuse01, fieldDiffuseMod01);
                let diffusedRight = processDiffusion (group, 1, groupLoopRight, fieldDiffuseDelaySamples, diffuse01, fieldDiffuseMod01);

                let shimmerShiftLeft = fieldShimmerSend > 0.0001f ? processShimmer (group, 0, diffusedLeft * fieldShimmerSend, fieldShimmerGrainSamples, fieldPitchRatio) : 0.0f;
                let shimmerShiftRight = fieldShimmerSend > 0.0001f ? processShimmer (group, 1, diffusedRight * fieldShimmerSend, fieldShimmerGrainSamples, fieldPitchRatio) : 0.0f;
                let shimmerBloomLeft = filterShimmerReturn (group, 0, shimmerShiftLeft, shimmerTone01);
                let shimmerBloomRight = filterShimmerReturn (group, 1, shimmerShiftRight, shimmerTone01);
                let shimmerMonitorLeft = shimmerBloomLeft * shimmerReturnGain01;
                let shimmerMonitorRight = shimmerBloomRight * shimmerReturnGain01;

                let bloomGain = feedbackMagnitude * (0.22f + 0.14f * fieldIndex + 0.34f * diffuse01);
                let bloomLeft = ((diffusedLeft * diffuseReturnGain01 * (0.30f + 0.24f * diffuse01)) + (shimmerMonitorLeft * (0.16f + 0.48f * shimmer01))) * bloomGain;
                let bloomRight = ((diffusedRight * diffuseReturnGain01 * (0.30f + 0.24f * diffuse01)) + (shimmerMonitorRight * (0.16f + 0.48f * shimmer01))) * bloomGain;

                for (wrap<choruslab::kInnerPairCount> innerPair)
                {
                    let polarity = ((int32 (group) + int32 (innerPair)) & 1) == 0 ? -1.0f : 1.0f;
                    let shape = 0.84f + 0.05f * fieldIndex + 0.04f * float32 (int32 (innerPair));

                    regenInjectionState[group, innerPair, 0] = bloomLeft * shape * (1.0f - 0.08f * polarity);
                    regenInjectionState[group, innerPair, 1] = bloomRight * shape * (1.0f + 0.08f * polarity);
                }

                shimmerSoloLeft += shimmerMonitorLeft / float32 (activeGroups);
                shimmerSoloRight += shimmerMonitorRight / float32 (activeGroups);
                shimmerPhase[group] = choruslab::wrap01 (shimmerPhase[group] + (1.0f / fieldShimmerGrainSamples));
            }

            let mainOut = (dry * dryGain) + (float32<2> (chorusWetLeft, chorusWetRight) * wetGain);
            out <- shimmerSolo ? float32<2> (shimmerSoloLeft, shimmerSoloRight) : mainOut;

            lfoPhase = choruslab::wrap01 (lfoPhase + (std::intrinsics::clamp (rateHz, 0.02f, 6.0f) / sampleRate));
            advance();
        }
    }
}
