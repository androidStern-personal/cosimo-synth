{
  "name": "cosimo-synth",
  "private": true,
  "type": "module",
  "scripts": {
    "ui:desktop:dev": "vite --config ui/vite.desktop.config.mjs",
    "ui:desktop:build": "node ui/build.mjs --desktop",
    "desktop:native:build": "./scripts/build_desktop_native.sh",
    "desktop:native:dev": "./scripts/run_desktop_native_dev.sh",
    "chorus:play": "cmaj play fx/chorus_lab/ChorusLab.cmajorpatch",
    "chorus:dry-run": "cmaj play --dry-run fx/chorus_lab/ChorusLab.cmajorpatch",
    "chorus:plugin:generate": "./scripts/generate_chorus_lab_plugin.sh",
    "chorus:jit:install": "./scripts/install_chorus_lab_cmajplugin.sh",
    "ott:play": "cmaj play fx/ott_lab/OttLab.cmajorpatch",
    "ott:dry-run": "cmaj play --dry-run --stop-on-error fx/ott_lab/OttLab.cmajorpatch",
    "ott:plugin:generate": "./scripts/generate_ott_lab_plugin.sh",
    "ott:jit:install": "./scripts/install_ott_lab_cmajplugin.sh",
    "test:ott:view": "node --test tests/test_ott_lab_view_browser.mjs",
    "test:effect-presets": "node --test tests/test_effect_preset_schema.mjs tests/test_effect_preset_state.mjs tests/test_effect_preset_contract.mjs tests/test_standalone_effect_presets.mjs tests/test_standalone_effect_preset_hook_browser.mjs",
    "ui:worker:build": "vite build --config ui/vite.worker.config.mjs",
    "ui:build": "node ui/build.mjs",
    "ios:ui:dev": "vite --config ios_auv3/vite.config.mjs",
    "ios:ui:build": "node ui/build.mjs --ios",
    "ios:project": "./scripts/generate_ios_auv3_xcode_project.sh build/ios_device_run",
    "test:desktop:ui": "node --test tests/test_desktop_patch_view_browser.mjs",
    "test:shared:hooks": "node --test tests/test_shared_synth_hooks_browser.mjs",
    "test:desktop:warp-ui": "npm run test:desktop:ui",
    "test:desktop:filter-ui": "npm run test:desktop:ui",
    "test:python:warp-alias": "uv run pytest tests/test_warp_aliasing.py",
    "test:python:filter-stability": "uv run pytest tests/test_filter_modulation_stability.py",
    "warp:fixtures:update-inputs": "node tests/helpers/generate_warp_cmajtest_fixtures.mjs && PYTHONPATH=. uv run python tests/helpers/generate_warp_reference_assets.py --expand-only",
    "warp:reference:update": "PYTHONPATH=. uv run --extra debug python tests/helpers/generate_warp_reference_assets.py",
    "warp:update-reference": "npm run warp:fixtures:update-inputs && npm run warp:reference:update",
    "test:cmajor:warp": "npm run test:python:warp-alias && npm run test:desktop:warp-ui && npm run test:shared:hooks && cmaj test --singleThread --sessionID=1 tests/cmajor_warp",
    "test:cmajor:filter": "npm run test:python:filter-stability && npm run test:desktop:filter-ui && npm run test:shared:hooks && cmaj test --singleThread --sessionID=1 tests/cmajor_filter"
  },
  "devDependencies": {
    "@react-grab/mcp": "0.1.29",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "playwright": "^1.59.0",
    "react-grab": "0.1.29",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.1.0"
  },
  "dependencies": {
    "nexusui": "^2.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
