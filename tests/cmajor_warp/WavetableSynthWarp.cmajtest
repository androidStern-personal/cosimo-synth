// Production-path Cmajor tests for the real patch main.
// These tests intentionally exercise WavetableSynth.cmajorpatch without a probe graph
// or a mainProcessor override.

const patchPath = "../../WavetableSynth.cmajorpatch";
const defaultFrequency = 44100;
const pythonReferenceMaxDiffDb = -65.0;
const bendPythonReferenceMaxDiffDb = -63.0;

function patchRun(subDir, blockSize, samplesToRender)
{
    return {
        patch: patchPath,
        subDir,
        frequency: defaultFrequency,
        blockSize,
        samplesToRender,
        sessionID: 1,
        skipMissingInputs: true
    };
}

function audioOnlyPatchRun(subDir, blockSize, samplesToRender, maxDiffDb)
{
    let options = patchRun (subDir, blockSize, samplesToRender);
    options.skipMissingOutputs = true;

    if (maxDiffDb !== undefined)
        options.maxDiffDb = maxDiffDb;

    return options;
}

