// Production-path filter tests for the real synth patch main.
// These tests intentionally exercise WavetableSynth.cmajorpatch instead of a probe voice graph.

const patchPath = "../../WavetableSynth.cmajorpatch";
const defaultFrequency = 44100;
const pythonReferenceMaxDiffDb = -65.0;

function audioOnlyPatchRun(subDir, blockSize, samplesToRender, maxDiffDb = pythonReferenceMaxDiffDb)
{
    return {
        patch: patchPath,
        subDir,
        frequency: defaultFrequency,
        blockSize,
        samplesToRender,
        sessionID: 1,
        skipMissingInputs: true,
        skipMissingOutputs: true,
        maxDiffDb
    };
}

## runScript (audioOnlyPatchRun("fixtures/filter_off_identity", 64, 4096))
