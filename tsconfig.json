{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": false,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "ui/**/*.ts",
    "ui/**/*.tsx"
  ]
}
