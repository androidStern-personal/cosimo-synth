{
  "name": "interface-extrusion-toolkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic DOM interface capture + Blender raised-panel scene generator.",
  "scripts": {
    "test:node": "node --test tests/node/*.test.mjs",
    "test:python": "python3 -m unittest discover -s tests/python -p 'test_*.py'",
    "test": "npm run test:node && npm run test:python",
    "export:example": "node src/browser/export-interface.mjs --manifest manifests/example.static.json --out captures/example-static",
    "serve:example": "node scripts/serve-static-example.mjs"
  },
  "dependencies": {
    "@playwright/test": "^1.52.0"
  },
  "devDependencies": {}
}
